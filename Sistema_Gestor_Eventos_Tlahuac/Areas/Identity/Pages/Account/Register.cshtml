@page
@model RegisterModel
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Registro de nuevos usuarios</h1>

    <div class="d-flex gap-2">

        <!-- Botón ir a página principal -->
        <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-secondary">
            <i class="bi bi-house"></i> Inicio
        </a>
    </div>

</div>


<div class="container mt-5">
    <div class="row shadow rounded overflow-hidden">

        <!-- LADO IZQUIERDO (IMAGEN / MENSAJE) -->
        <div class="col-md-6 text-white d-flex flex-column justify-content-center align-items-center p-5">

            <img src="~/Imagenes/Imagen1.jpg" class="img-fluid mt-4" style="max-height:300px;" />

        </div>

        <!-- LADO DERECHO (FORMULARIO) -->
        <div class="col-md-6 p-5">

            <h3 class="mb-4">Crear cuenta</h3>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- NOMBRE -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Nombre" class="form-control" placeholder="Nombre" />
                    <label asp-for="Input.Nombre">Nombre</label>
                    <span asp-validation-for="Input.Nombre" class="text-danger"></span>
                </div>

                <!-- APELLIDO -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.ApellidoPaterno" class="form-control" placeholder="Apellido Paterno" />
                    <label asp-for="Input.ApellidoPaterno">Apellido Paterno</label>
                    <span asp-validation-for="Input.ApellidoPaterno" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.ApellidoMaterno" class="form-control" placeholder="Apellido Materno" />
                    <label asp-for="Input.ApellidoMaterno">Apellido Materno</label>
                    <span asp-validation-for="Input.ApellidoMaterno" class="text-danger"></span>
                </div>

                <!-- EMAIL -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="correo@ejemplo.com" />
                    <label asp-for="Input.Email">Correo electrónico</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <!-- CONTRASEÑA -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Contraseña" />
                    <label asp-for="Input.Password">Contraseña</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <!-- CONFIRMAR CONTRASEÑA -->
                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Confirmar contraseña" />
                    <label asp-for="Input.ConfirmPassword">Confirmar contraseña</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button id="registerSubmit" type="submit" class="w-100 btn btn-crear">
                    Registrarse
                </button>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}