@model Sistema_Gestor_Eventos_Tlahuac.Models.Categoria

@{
    ViewData["Title"] = "Editar la categoria";
}
<partial name="_Header_Vistas" />

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-body">

                <form asp-action="Edit">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label"></label>

                        <textarea asp-for="Descripcion"
                                  class="form-control"
                                  rows="5"
                                  placeholder="Escribe una descripción...">
                        </textarea>

                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-check-label">
                            <input class="form-check-input" asp-for="Activo" /> @Html.DisplayNameFor(model => model.Activo)
                        </label>

                    </div>

                    <partial name="_Botones_Formulario" />
                </form>

            </div>

        </div>

    </div>

</div>