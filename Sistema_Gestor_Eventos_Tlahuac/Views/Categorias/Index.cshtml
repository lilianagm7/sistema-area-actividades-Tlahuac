@model IEnumerable<Sistema_Gestor_Eventos_Tlahuac.Models.Categoria>

@{
    ViewData["Title"] = "Categorias";
    ViewData["ShowSearch"] = true;

    var buttons = new List<dynamic>();
    if (User.IsInRole("Administrador"))
    {
        buttons.Add(new { Text = "Crear evento", Action = "Create", Color = "crear" });
    }
    ViewData["Buttons"] = new List<dynamic>
    {
        new { Text = "Regresar", Action = "Index", Color = "secondary" }
    };
}
<partial name="_Header" />

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Descripcion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Activo)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Nombre)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Descripcion)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Activo)
                </td>
                <td>
                    <partial name="_BotonesdeCRUD" model="item.Id" />
                </td>

            </tr>
        }
    </tbody>
</table>
