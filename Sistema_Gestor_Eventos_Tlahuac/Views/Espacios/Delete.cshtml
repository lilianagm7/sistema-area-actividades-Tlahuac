@model Sistema_Gestor_Eventos_Tlahuac.Models.Catalogos.Espacio

@{
    ViewData["Title"] = "Eliminar un espacio";

    ViewData["Buttons"] = new List<dynamic>
    {
        new { Text = "Regresar", Action = "Index", Color = "secondary" }
    };
}
<partial name="_Header" />

<hr />
<br>
<p>¿Estas seguro de eliminar el espacio?</p></br>

<dl class="row">
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Nombre)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Nombre)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Capacidad)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Capacidad)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Activo)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Activo)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Lugar)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Lugar.Nombre)
    </dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn btn-danger" /> |
    <a asp-action="Index">Back to List</a>
</form>
</div>
