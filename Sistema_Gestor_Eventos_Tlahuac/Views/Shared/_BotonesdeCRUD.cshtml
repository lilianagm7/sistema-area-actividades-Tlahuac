@{
}
@model int

<div class="btn-group gap-1 gap-1" role="group">

    <a asp-action="Edit"
       asp-route-id="@Model"
       class="btn btn-sm btn-modificar">
        <i class="bi bi-pencil"></i>
    </a>

    <br>
    @if (User.IsInRole("Administrador"))
    {
        <a asp-action="Delete"
           asp-route-id="@Model"
           class="btn btn-sm btn-eliminar">
            <i class="bi bi-trash-fill"></i>
        </a>
    }
</div>