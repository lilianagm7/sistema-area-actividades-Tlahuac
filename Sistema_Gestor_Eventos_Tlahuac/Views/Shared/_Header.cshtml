<div class="d-flex justify-content-between align-items-center mb-3">

    <h1 class="mb-0">@ViewData["Title"]</h1>

    <div class="d-flex align-items-center gap-2">

        @* Buscador opcional *@
        @if (ViewData["ShowSearch"] != null && (bool)ViewData["ShowSearch"])
        {
            <form method="get" class="d-flex">
                <input type="text"
                       name="search"
                       value="@Context.Request.Query["search"]"
                       class="form-control form-control-sm me-2"
                       style="width: 300px;"
                       placeholder="Buscar..." />

                <button type="submit" class="btn btn-dorado">
                    <i class="bi bi-search"></i> 
                </button>
            </form>
        }

        @* Botones *@
        @if (ViewData["Buttons"] != null)
        {
            foreach (var button in (List<dynamic>)ViewData["Buttons"])
            {
                <a asp-action="@button.Action"
                   class="btn btn-@button.Color">
                    @button.Text
                </a>
            }
        }

    </div>
</div>